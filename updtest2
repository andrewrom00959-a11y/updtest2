	local function calculate3DSize(guiObject, distance)
		local screenWidth = camera.ViewportSize.X
		local screenHeight = camera.ViewportSize.Y

		local pixelWidth = guiObject.AbsoluteSize.X
		local pixelHeight = guiObject.AbsoluteSize.Y

		local fov = camera.FieldOfView
		local aspect_ratio = screenWidth / screenHeight

		local view_height = 2 * math.tan(math.rad(fov / 2)) * distance
		local view_width = view_height * aspect_ratio

		local scale_x = pixelWidth / screenWidth
		local scale_y = pixelHeight / screenHeight

		local size_x = view_width * scale_x
		local size_y = view_height * scale_y

		local part_size = Vector3.new(size_x, size_y, 0.01)

		return part_size
	end

