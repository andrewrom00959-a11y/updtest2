	local function teleportPlayerN2(x, y, z)
		if not (x and y and z) then return end
		local player = game:GetService("Players").LocalPlayer
		local character = player.Character
		if not character or not character:FindFirstChild("HumanoidRootPart") then return end
		local humanoidRootPart = character.HumanoidRootPart
		local doorsFolder = workspace:FindFirstChild("Doors")
		local ignoreList = {}
		if doorsFolder then
			for _, v in pairs(doorsFolder:GetChildren()) do
				if v.Name == "Door" then
					table.insert(ignoreList, v)
				end
			end
		end
		local targetPosition = Vector3.new(x, y, z)
		local path = PathfindingService:CreatePath({
			AgentRadius = 1.5,
			AgentHeight = 2,
			AgentCanJump = true,
			Costs = {
				["Door"] = 1
			}
		})
		local success, errorMessage = pcall(function()
			path:ComputeAsync(humanoidRootPart.Position, targetPosition)
		end)
		if success and path.Status == Enum.PathStatus.Success then
			local waypoints = path:GetWaypoints()
			if teleporting then return end
			teleporting = true
			for _, waypoint in pairs(waypoints) do
				local currentWaypointPosition = waypoint.Position + Vector3.new(0, 2.5, 0)
				local targetCFrameForWaypoint = CFrame.new(currentWaypointPosition) * CFrame.Angles(humanoidRootPart.CFrame:ToEulerAnglesXYZ())
				local tween = TweenService:Create(humanoidRootPart, TweenInfo.new(0.06), {CFrame = targetCFrameForWaypoint})
				tween:Play()
				tween.Completed:Wait()
				if waypoint.Action == Enum.PathWaypointAction.Jump then
					humanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 50, 0)
				end
			end
			teleporting = false
		end
	end



