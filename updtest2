		local panels = {}
		for _, child in ipairs(pressurePanels:GetChildren()) do
			if child.Name == "Panel" then
				table.insert(panels, child)
			end
		end
		for _, panel in ipairs(panels) do
			local failing = panel:FindFirstChild("Failing")
			if not failing or failing.Value then
